<Window x:Class="CSH_Monitor.UI.Features.EntryWindow.EntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:edge="clr-namespace:CSH_Monitor.UI"
        xmlns:behaviors="clr-namespace:CSH_Monitor.UI.Behaviors"
        xmlns:local="clr-namespace:CSH_Monitor.UI.Features.EntryWindow"
        mc:Ignorable="d"
        MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Title="CSH Monitor v0.1.0-unstable" Height="720" Width="1280">
    <i:Interaction.Behaviors>
        <behaviors:WindowSizeBehavior Width="{Binding WindowWidth, Mode=OneWayToSource}" Height="{Binding WindowHeight, Mode=OneWayToSource}"/>
    </i:Interaction.Behaviors>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" VerticalAlignment="Top" Background="White">
            <MenuItem Header="File">

            </MenuItem>
            <MenuItem Header="Edit" >

            </MenuItem>
            <MenuItem Header="View" >

            </MenuItem>
        </Menu>

        <Border Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                <!--Button Content="" Margin="5,0"/-->
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"  Margin="0,22,0,0" BorderBrush="DarkGray" BorderThickness="1,1,0,1">

            </Border>

            <Border Grid.Column="1">
                <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                    <TabItem Header="Сертификация">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="5*"/>
                            </Grid.ColumnDefinitions>

                        </Grid>
                    </TabItem>
                    <TabItem Header="Стабильность">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">

                            </StackPanel>

                            <oxy:PlotView Grid.Row="1"
                                      Controller="{Binding СustomController}"
                                      Model="{Binding StabilityPlotModel}"/>

                            <StackPanel Grid.Row="2">

                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Однородность">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>


                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>
            <Border Grid.Column="2" Margin="0,22,0,0" BorderBrush="DarkGray" BorderThickness="0,1,1,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Command="{Binding GetData}" BorderThickness="0.5">
                        <TextBlock Text="Ввести данные" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Button>
                    <TextBox Grid.Row="1" Text="{Binding MainDataString}" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto" BorderThickness="0.5"/>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <WrapPanel>
                    <TextBlock Text="Строка состояния" Margin="5,0"/>
                    <TextBlock Text="{Binding WindowWidth}" Margin="5,0"/>
                    <TextBlock Text="{Binding WindowHeight}" Margin="5,0"/>
                </WrapPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>